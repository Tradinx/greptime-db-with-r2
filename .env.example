# Copy to .env and fill in. .env is gitignored — never commit it.
#   cp .env.example .env && chmod 600 .env

# Cloudflare R2 API token scoped to the `ohlcv` bucket (Object Read & Write).
# Create at: Cloudflare dashboard -> R2 -> Manage API Tokens.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Password for the `admin` user on the MySQL/Postgres/HTTP endpoints.
GREPTIME_ADMIN_PASSWORD=

# Host interface to publish ports on. Defaults to 0.0.0.0 (all interfaces).
# Set to 127.0.0.1 on an internet-facing host and put a reverse proxy in front.
# BIND_HOST=127.0.0.1
